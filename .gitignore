# =========================
# ROOT .gitignore
# =========================

# Dependency directories
node_modules/
*/node_modules/

# Environment variables (CRITICAL)
.env
.env.*
*/.env
*/.env.*

# Build and production output
dist/
*/dist/
build/
*/build/
out/
*/out/

# Vite / React cache
.vite/
*/.vite/

# Logs
*.log
*/logs/
npm-debug.log*
yarn-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor folders
.vscode/
.idea/

# Misc
*.swp
*.swo
.project
.classpath
.settings/
